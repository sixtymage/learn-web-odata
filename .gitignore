## .gitignore for learn-web-odata
## Covers both the original .NET scaffold and the actual Node.js/CAP stack.

# ---- Node.js / npm ----
node_modules/
npm-debug.log*
.npm/

# ---- SAP CAP ----
# Generated artifacts and local SQLite database files
gen/
*.db
*.sqlite
.cds-services.json

# ---- Docker ----
# Don't commit any local override compose files
docker-compose.override.yml

# ---- Environment / secrets ----
.env
.env.local

# ---- VS Code ----
.vscode/settings.json
.vscode/launch.json

# ============================================================
# Original .NET entries (kept for reference / future use)
# ============================================================

