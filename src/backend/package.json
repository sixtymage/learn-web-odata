{
  "name": "learn-web-odata-backend",
  "version": "1.0.0",
  "description": "SAP CAP backend for the learn-web-odata learning repo",
  "main": "server.js",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@sap/cds": "^8",
    "express": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8",
    "@cap-js/postgres": "^1",
    "sqlite3": "^5"
  },
  "scripts": {
    "start":     "cds-serve",
    "watch":     "cds watch",
    "build":     "cds build",
    "deploy:pg": "cds deploy --profile postgres",
    "watch:pg":  "cds watch --profile postgres"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "database": ":memory:"
        }
      }
    },
    "[postgres]": {
      "requires": {
        "db": {
          "kind": "postgres",
          "credentials": {
            "host":     "localhost",
            "port":     5432,
            "database": "odata_learn",
            "user":     "cap_user",
            "password": "cap_password"
          }
        }
      }
    }
  }
}
