{
  "name": "learn-web-odata-backend",
  "version": "1.0.0",
  "description": "SAP CAP backend for the learn-web-odata learning repo",
  "main": "server.js",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@sap/cds": "^8",
    "express": "^4"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8",
    "sqlite3": "^5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "cds build"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "database": ":memory:"
        }
      }
    }
  }
}
