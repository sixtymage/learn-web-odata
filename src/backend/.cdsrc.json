{
  "requires": {
    "db": {
      "kind": "sqlite",
      "credentials": {
        "database": ":memory:"
      }
    }
  },
  "features": {
    "serve_on_root": true
  },
  "server": {
    "cors": [
      {
        "origin": "*",
        "allowedHeaders": ["Content-Type", "Authorization", "x-csrf-token"]
      }
    ]
  }
}
